generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMs ───────────────────────────────────────────────────────────────────

enum PapelUsuario {
  aluno
  admin
  pastor
}

enum StatusIA {
  pendente
  processando
  concluido
  erro
}

enum StatusEntrega {
  pendente
  enviado
  corrigido
}

enum StatusPresenca {
  presente
  parcial
  ausente
}

enum MetodoPresenca {
  digital
  meet
  presencial
}

enum FormatoAvaliacao {
  discursiva
  objetiva
}

enum TipoAlertaSeguranca {
  novo_ip
  login_falho
  senha_alterada
}

enum StatusCadastroAluno {
  pendente
  aprovado
  rejeitado
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model User {
  id            String        @id @default(uuid())
  nome          String
  email         String        @unique
  senhaHash     String
  papel         PapelUsuario  @default(aluno)
  foto          String?
  telefone      String?
  ativo         Boolean       @default(true)
  statusCadastro StatusCadastroAluno @default(aprovado)
  dataNascimento DateTime?
  membroVinha    Boolean      @default(false)
  batizado       Boolean      @default(false)
  criadoEm      DateTime      @default(now())
  ultimoAcesso  DateTime?
  compartilhaDadosIA    Boolean  @default(false)
  aiCreditosDisponiveis Int      @default(3)
  aiCreditosUltimaRecarga DateTime @default(now())

  progressos        ProgressoAluno[]
  resultadosQuiz    ResultadoQuiz[]
  notificacoes      Notificacao[]
  anotacoes         AnotacaoAluno[]
  loginHistorico    LoginHistorico[]
  presencas         Presenca[]
  interacoesIA      InteracaoIA[]
  entregasAvaliacao EntregaAvaliacao[]
  registrosConteudo RegistroMudancaConteudo[]
  alertasSeguranca  AlertaSeguranca[]

  @@index([papel])
  @@index([ultimoAcesso])
  @@index([ativo])
  @@index([statusCadastro])
}

model Modulo {
  id        String   @id @default(uuid())
  titulo    String
  descricao String?
  capaUrl   String?
  ordem     Int      @default(0)
  obrigatorio Boolean @default(true)
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  aulas     Aula[]
  avaliacoes Avaliacao[]
  materiais Material[]

  @@index([ativo])
  @@index([ordem])
}

model Aula {
  id              String    @id @default(uuid())
  moduloId        String
  titulo          String
  descricao       String?
  urlVideo        String?
  thumbnail       String?
  duracaoSegundos Int       @default(0)
  publicado       Boolean   @default(false)
  dataPublicacao  DateTime?
  transcricao     String?   @db.Text
  resumo          String?   @db.Text
  pontosChave     String?   @db.Text
  versiculos      String?   @db.Text
  glossario       String?   @db.Text
  statusIA        StatusIA  @default(pendente)
  criadoEm        DateTime  @default(now())

  modulo         Modulo           @relation(fields: [moduloId], references: [id], onDelete: Cascade)
  quizzes        Quiz[]
  progressos     ProgressoAluno[]
  resultadosQuiz ResultadoQuiz[]
  anotacoes      AnotacaoAluno[]
  presencas      Presenca[]
  materiaisAula  MaterialAula[]
  interacoesIA   InteracaoIA[]
  avaliacoes     Avaliacao[]

  @@index([moduloId])
  @@index([publicado])
  @@index([criadoEm(sort: Desc)])
  @@index([statusIA])
}

model Avaliacao {
  id                 String           @id @default(uuid())
  titulo             String
  descricao          String?
  tipo               String           @default("trabalho")
  formato            FormatoAvaliacao @default(discursiva)
  moduloId           String?
  aulaId             String?
  dataLimite         DateTime?
  notaMaxima         Float            @default(10)
  publicado          Boolean          @default(false)
  permiteArquivo     Boolean          @default(true)
  permiteTexto       Boolean          @default(false)
  questoesObjetivas  String?          @db.Text
  resultadoImediato  Boolean          @default(true)
  tempoLimiteMinutos Int?
  criadoEm           DateTime         @default(now())

  modulo   Modulo?            @relation(fields: [moduloId], references: [id], onDelete: SetNull)
  aula     Aula?              @relation(fields: [aulaId], references: [id], onDelete: SetNull)
  entregas EntregaAvaliacao[]

  @@index([publicado])
  @@index([moduloId])
  @@index([aulaId])
  @@index([dataLimite])
}

model EntregaAvaliacao {
  id                 String        @id @default(uuid())
  avaliacaoId        String
  alunoId            String
  respostaTexto      String?       @db.Text
  arquivoUrl         String?
  respostasObjetivas String?       @db.Text
  status             StatusEntrega @default(pendente)
  nota               Float?
  totalQuestoes      Int?
  acertosObjetivos   Int?
  percentualObjetivo Float?
  comentarioCorrecao String?       @db.Text
  enviadoEm          DateTime?
  corrigidoEm        DateTime?
  atualizadoEm       DateTime      @updatedAt
  criadoEm           DateTime      @default(now())

  avaliacao Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  aluno     User      @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@unique([avaliacaoId, alunoId])
  @@index([alunoId])
  @@index([avaliacaoId])
  @@index([status])
  @@index([corrigidoEm])
}

model Quiz {
  id       String @id @default(uuid())
  aulaId   String
  questoes String @db.Text

  aula Aula @relation(fields: [aulaId], references: [id], onDelete: Cascade)

  @@index([aulaId])
}

model ProgressoAluno {
  id                   String    @id @default(uuid())
  alunoId              String
  aulaId               String
  percentualAssistido  Float     @default(0)
  tempoTotalSegundos   Int       @default(0)
  concluido            Boolean   @default(false)
  dataInicio           DateTime  @default(now())
  dataConclusao        DateTime?
  posicaoAtualSegundos Float     @default(0)
  vezesQueParou        Int       @default(0)
  sessoes              Int       @default(0)

  aluno User @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  aula  Aula @relation(fields: [aulaId], references: [id], onDelete: Cascade)

  @@unique([alunoId, aulaId])
  @@index([alunoId])
  @@index([aulaId])
  @@index([concluido])
  @@index([alunoId, concluido])
}

model ResultadoQuiz {
  id            String   @id @default(uuid())
  alunoId       String
  aulaId        String
  respostas     String   @db.Text
  pontuacao     Int
  totalQuestoes Int
  feitoEm       DateTime @default(now())

  aluno User @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  aula  Aula @relation(fields: [aulaId], references: [id], onDelete: Cascade)

  @@index([alunoId])
  @@index([aulaId])
  @@index([feitoEm(sort: Desc)])
}

model Material {
  id              String   @id @default(uuid())
  titulo          String
  descricao       String?
  urlArquivo      String
  tipo            String   @default("pdf")
  categoria       String   @default("geral")
  permiteDownload Boolean  @default(false)
  moduloId        String?
  criadoEm        DateTime @default(now())

  modulo       Modulo?        @relation(fields: [moduloId], references: [id], onDelete: SetNull)
  materiaisAula MaterialAula[]

  @@index([categoria])
  @@index([moduloId])
  @@index([criadoEm(sort: Desc)])
}

model MaterialAula {
  id         String @id @default(uuid())
  materialId String
  aulaId     String

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  aula     Aula     @relation(fields: [aulaId], references: [id], onDelete: Cascade)

  @@unique([materialId, aulaId])
  @@index([aulaId])
  @@index([materialId])
}

model Presenca {
  id           String         @id @default(uuid())
  alunoId      String
  aulaId       String
  status       StatusPresenca @default(ausente)
  metodo       MetodoPresenca @default(digital)
  percentual   Float          @default(0)
  registradoEm DateTime       @default(now())

  aluno User @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  aula  Aula @relation(fields: [aulaId], references: [id], onDelete: Cascade)

  @@unique([alunoId, aulaId])
  @@index([alunoId])
  @@index([aulaId])
  @@index([status])
}

model Notificacao {
  id       String   @id @default(uuid())
  alunoId  String
  titulo   String
  mensagem String
  lida     Boolean  @default(false)
  criadaEm DateTime @default(now())

  aluno User @relation(fields: [alunoId], references: [id], onDelete: Cascade)

  @@index([alunoId])
  @@index([alunoId, lida])
}

model AnotacaoAluno {
  id           String   @id @default(uuid())
  alunoId      String
  aulaId       String
  conteudo     String   @default("") @db.Text
  atualizadoEm DateTime @default(now())

  aluno User @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  aula  Aula @relation(fields: [aulaId], references: [id], onDelete: Cascade)

  @@unique([alunoId, aulaId])
  @@index([alunoId])
}

model LoginHistorico {
  id          String   @id @default(uuid())
  usuarioId   String
  ip          String?
  dispositivo String?
  dataHora    DateTime @default(now())
  sucesso     Boolean  @default(true)

  usuario User @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([dataHora(sort: Desc)])
  @@index([usuarioId, sucesso])
}

model InteracaoIA {
  id       String   @id @default(uuid())
  alunoId  String
  aulaId   String?
  pergunta String   @db.Text
  resposta String   @db.Text
  criadoEm DateTime @default(now())

  aluno User  @relation(fields: [alunoId], references: [id])
  aula  Aula? @relation(fields: [aulaId], references: [id])

  @@index([alunoId])
  @@index([aulaId])
}

model AlertaSeguranca {
  id          String              @id @default(uuid())
  usuarioId   String
  tipo        TipoAlertaSeguranca
  mensagem    String
  ip          String?
  dispositivo String?
  lido        Boolean             @default(false)
  criadoEm   DateTime             @default(now())

  usuario User @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
  @@index([lido])
}

model RegistroMudancaConteudo {
  id             String   @id @default(uuid())
  usuarioId      String?
  usuarioNome    String
  entidade       String
  entidadeId     String?
  entidadeTitulo String
  acao           String
  detalhes       String?
  criadoEm       DateTime @default(now())

  usuario User? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([criadoEm(sort: Desc)])
  @@index([entidade, entidadeId])
}
