# DATABASE_URL="postgresql://seminario:seminario_dev@localhost:5432/seminario"
# DIRECT_URL="postgresql://seminario:seminario_dev@localhost:5432/seminario"

# Produção (Supabase — substitua [YOUR-PASSWORD]):
DATABASE_URL="postgresql://postgres.nqqkziekbhapzyieapnr:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.nqqkziekbhapzyieapnr:[YOUR-PASSWORD]@aws-0-us-west-2.pooler.supabase.com:5432/postgres"

# Produção self-hosted (docker-compose.prod.yml — defina POSTGRES_PASSWORD):
# DATABASE_URL="postgresql://seminario:${POSTGRES_PASSWORD}@postgres:5432/seminario"
# DIRECT_URL="postgresql://seminario:${POSTGRES_PASSWORD}@postgres:5432/seminario"

