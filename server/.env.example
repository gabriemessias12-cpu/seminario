PORT=3001
CORS_ORIGIN=https://seminario.seu-dominio.com
JWT_SECRET=troque-esta-chave-por-string-aleatoria-longa
JWT_REFRESH_SECRET=troque-esta-chave-por-string-aleatoria-longa

# ─── PostgreSQL (Supabase) ────────────────────────────────────────────────────
# 1. Crie uma conta gratuita em https://supabase.com
# 2. Crie um projeto (anote a senha do banco!)
# 3. Vá em Settings > Database > Connection string
#
# DATABASE_URL       → "Transaction" pooler  (porta 6543) — usado pela aplicação
# DATABASE_URL_UNPOOLED → "Session" pooler ou "Direct" (porta 5432) — usado para migrations
#
# Exemplo (substitua [PROJECT-REF] e [PASSWORD]:
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DATABASE_URL_UNPOOLED=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
