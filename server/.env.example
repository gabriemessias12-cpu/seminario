PORT=3001
CORS_ORIGIN=https://seminario.seu-dominio.com
JWT_SECRET=troque-esta-chave-por-string-aleatoria-longa
JWT_REFRESH_SECRET=troque-esta-chave-por-string-aleatoria-longa

# ─── PostgreSQL (Neon.tech) ───────────────────────────────────────────────────
# 1. Crie uma conta gratuita em https://neon.tech
# 2. Crie um projeto e um banco chamado "seminario"
# 3. Na aba "Connection Details", copie:
#    - "Connection string"  → DATABASE_URL     (pooled, começa com postgres://...@ep-...)
#    - "Direct connection"  → DATABASE_URL_UNPOOLED (direto, para migrations)
DATABASE_URL=postgres://user:password@ep-xxx.neon.tech/seminario?sslmode=require
DATABASE_URL_UNPOOLED=postgres://user:password@ep-xxx.neon.tech/seminario?sslmode=require&pgbouncer=false

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
